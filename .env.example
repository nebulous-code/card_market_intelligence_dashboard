# Database — Neon connection string
# Get this from your Neon project dashboard: https://neon.tech
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/pokemon_cards?sslmode=require

# Ingestion — pokemontcg.io API key
# Optional: omit for unauthenticated requests (lower rate limits)
# Get a key at: https://pokemontcg.io
POKEMONTCG_API_KEY=your_key_here

# Frontend — base URL for API requests
VITE_API_BASE_URL=http://localhost:8000
