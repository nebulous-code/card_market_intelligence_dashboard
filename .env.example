# Database — Neon connection string
# Get this from your Neon project dashboard: https://neon.tech
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/pokemon_cards?sslmode=require

# Frontend — base URL for API requests
VITE_API_BASE_URL=http://localhost:8000

# PokemonPriceTracker — pricing data source (Milestone 2)
# Get your API key at https://www.pokemonpricetracker.com
POKEMON_PRICE_TRACKER_API_KEY=your_key_here

# Tier flags — controls what PokemonPriceTracker returns per card.
# Free tier (100 credits/day): set both to false.
# API tier ($9.99/mo, 20,000 credits/day): set to true for the initial backfill
# run, then revert to false for nightly snapshot runs.
PPT_INCLUDE_HISTORY=false
PPT_HISTORY_DAYS=180

# Set to true on API tier only — fetches eBay/PSA graded prices (+1 credit/card).
PPT_INCLUDE_EBAY=false
